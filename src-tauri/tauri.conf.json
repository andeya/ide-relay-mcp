{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Relay",
  "version": "1.0.0",
  "identifier": "com.relay.mcp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Relay MCP",
        "width": 580,
        "height": 380,
        "resizable": true,
        "center": true,
        "alwaysOnTop": true,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}